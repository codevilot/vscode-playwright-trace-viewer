{
  "name": "playwright-trace-viewer",
  "displayName": "Playwright Trace Viewer",
  "description": "A lightweight helper for opening Playwright trace.zip files from VS Code.",
  "version": "0.0.1",
  "publisher": "codevilot",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/codevilot/vscode-playwright-trace-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/codevilot/vscode-playwright-trace-viewer/issues"
  },
  "homepage": "https://github.com/codevilot/vscode-playwright-trace-viewer#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCustomEditor:playwrightTraceViewer.traceZipEditor",
    "onCommand:playwrightTraceViewer.openLatestTrace",
    "onCommand:playwrightTraceViewer.openSelectedTrace",
    "onCommand:playwrightTraceViewer.openReport",
    "onCommand:playwrightTraceViewer.runTestsWithTrace",
    "onCommand:playwrightTraceViewer.runTestsRetainTrace"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.3.3"
  },
  "contributes": {
    "commands": [
      {
        "command": "playwrightTraceViewer.openLatestTrace",
        "title": "Playwright Trace Viewer: Open Latest Trace"
      },
      {
        "command": "playwrightTraceViewer.openSelectedTrace",
        "title": "Open Playwright Trace"
      },
      {
        "command": "playwrightTraceViewer.openReport",
        "title": "Playwright Trace Viewer: Open Report"
      },
      {
        "command": "playwrightTraceViewer.runTestsWithTrace",
        "title": "Playwright Trace Viewer: Run Tests with Trace"
      },
      {
        "command": "playwrightTraceViewer.runTestsRetainTrace",
        "title": "Playwright Trace Viewer: Run Tests Retain Trace on Failure"
      }
    ],
    "configuration": {
      "title": "Playwright Trace Viewer",
      "properties": {
        "playwrightTraceViewer.traceGlob": {
          "type": "string",
          "default": "test-results/**/trace.zip",
          "description": "Glob used to find Playwright trace.zip files in the current workspace."
        },
        "playwrightTraceViewer.packageRunner": {
          "type": "string",
          "default": "npx",
          "description": "Package runner used to invoke Playwright. Common values: npx, pnpm, yarn."
        }
      }
    },
    "customEditors": [
      {
        "viewType": "playwrightTraceViewer.traceZipEditor",
        "displayName": "Playwright Trace",
        "selector": [
          {
            "filenamePattern": "**/trace.zip"
          }
        ],
        "priority": "default"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "playwrightTraceViewer.openSelectedTrace",
          "when": "resourceFilename == trace.zip",
          "group": "navigation@1"
        }
      ],
      "editor/title/context": [
        {
          "command": "playwrightTraceViewer.openSelectedTrace",
          "when": "resourceFilename == trace.zip",
          "group": "navigation@1"
        }
      ]
    }
  },
  "dependencies": {
    "playwright-core": "^1.60.0"
  }
}
